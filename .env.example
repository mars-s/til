# Copy this file to .env — NEVER commit .env to git
# Supabase now uses publishable/secret key format (replaces anon/service_role)

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_DB_PASSWORD=

# ─── Google OAuth (Web Application client from Google Cloud Console) ──────────
# Redirect URI to set in Google console: https://<ref>.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Anthropic (OPTIONAL — AI smart scheduling) ───────────────────────────────
# Set AI_SCHEDULING_ENABLED=true in Supabase Edge Function secrets to activate.
# Without this, the app uses the local heuristic scheduler (always available offline).
ANTHROPIC_API_KEY=
AI_SCHEDULING_ENABLED=false

# ─── Mobile (Expo — EXPO_PUBLIC_ prefix exposes to client bundle) ─────────────
# apps/mobile/.env
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
