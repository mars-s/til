{
  "expo": {
    "name": "til",
    "slug": "til",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "til",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.til.app",
      "deploymentTarget": "17.0"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
